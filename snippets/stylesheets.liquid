{% comment %}  layout-container页面安全区域 {% endcomment %}
<style>
    :root {
        --layout-container-horizontal-space: 16px;
        --layout-container-max-width: 100%;
        --heading-content-space: 20px;
    }
    @media (min-width: 768px){
        :root {
            --layout-container-horizontal-space: 32px;
        }
    }
    @media (min-width: 1024px){
        :root {
            --layout-container-horizontal-space: 48px;
        }
    }
    @media (min-width: 1536px){
        :root {
            --layout-container-horizontal-space: 0;
            --layout-container-max-width: 1440px;
            --heading-content-space: 32px;
        }
    }

    .layout-container {
        padding-left: var(--layout-container-horizontal-space);
        padding-right: var(--layout-container-horizontal-space);
        margin-left: auto;
        margin-right: auto;
        max-width: var(--layout-container-max-width);
    }
</style>