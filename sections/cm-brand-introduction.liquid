
{% schema %}
    {
        "name": "品牌介绍",
        "settings": [
            { "type": "header","content":"配置"},
            { "type": "select", "id": "section_width", "label": "版块宽度", "default": "global-width", "options": [
                { "value": "full-width", "label": "版块全宽" },
                { "value": "full-content-width", "label": "版块全宽, 内容区域跟随全局宽度" },
                { "value": "global-width", "label": "版块跟随全局宽度" },
                { "value": "custom-width", "label": "版块自定义宽度" }
            ]},
            { "type": "number", "id": "section_width_custom", "label": "自定义宽度", "default": 1440, "info": "自定义宽度, 默认1440px", "visible_if": "{{ section.settings.section_width == 'custom-width' }}" },

            { "type": "header","content":"版块设置"},
            { "type": "color", "id": "bg_color", "label": "背景颜色", "default": "transparent" },
            { "type": "paragraph", "content": "标题区域" },
            { "type": "textarea", "id": "heading", "label": "标题" },
            { "type": "textarea", "id": "subheading", "label": "副标题" },
            { "type": "select", "id": "header_alignment", "label": "标题对齐", "default": "center",
            "options": [
                { "value": "center", "label": "居中" },
                { "value": "left", "label": "靠左" },
                { "value": "right", "label": "靠右" }
            ]
            },
            { "type": "number", "id": "heading_font_size", "label": "标题字号 (电脑端)", "default": 36 },
            { "type": "number", "id": "heading_font_size_mb", "label": "标题字号 (手机端)", "default": 28 },
            { "type": "color", "id": "heading_color", "label": "标题颜色", "default": "#141414" },
            { "type": "number", "id": "subheading_font_size", "label": "副标题字号 (电脑端)", "default": 18 },
            { "type": "number", "id": "subheading_font_size_mb", "label": "副标题字号 (手机端)", "default": 16 },
            { "type": "color", "id": "subheading_color", "label": "副标题颜色", "default": "#141414" },

            { "type": "header","content":"视频"},
            { "type": "video_url", "id": "video_url", "label": "视频URL", "info": "支持YouTube和Vimeo", "accept": ["youtube", "vimeo"] },

            { "type": "header","content":"文本1"},
            { "type": "textarea", "id": "text1_heading", "label": "文本1标题" },
            { "type": "textarea", "id": "text1_text", "label": "文本1内容" },
            { "type": "color", "id": "text1_bg_color", "label": "文本1背景颜色", "default": "transparent" },
            { "type": "textarea", "id": "text2_heading", "label": "文本2标题" },
            { "type": "textarea", "id": "text2_text", "label": "文本2内容" },
            { "type": "color", "id": "text2_bg_color", "label": "文本2背景颜色", "default": "transparent" },

            { "type": "checkbox", "id": "remove_top_padding", "label": "移除上边距", "default": false },
            { "type": "checkbox", "id": "remove_bottom_padding", "label": "移除下边距", "default": false },
            { "type": "text", "id": "custom_class", "label": "自定义class" }
        ],

        "presets": [
            {
                "name": "品牌介绍",
                "category": "custom"
            }
        ]
    }
{% endschema %}



{{ 'cm-brand-introduction.css' | asset_url | stylesheet_tag }}
<style>
[data-section-id="{{ section.id }}"] {
    --bg-color:{{ section.settings.bg_color }};
    --cm-ml-header-align:{{ section.settings.header_alignment }};
    --cm-ml-heading-size:{{ section.settings.heading_font_size }}px;
    --cm-ml-heading-size-mb:{{ section.settings.heading_font_size_mb }}px;
    --cm-ml-heading-color:{{ section.settings.heading_color }};
    --cm-ml-subheading-size:{{ section.settings.subheading_font_size }}px;
    --cm-ml-subheading-size-mb:{{ section.settings.subheading_font_size_mb }}px;
    --cm-ml-subheading-color:{{ section.settings.subheading_color }};
    --text1-bg-color:{{ section.settings.text1_bg_color }};
    --text2-bg-color:{{ section.settings.text2_bg_color }};

    {% if section.settings.section_width == 'custom-width' %}
        --section-width:{{ section.settings.section_width_custom }}px;
    {% elsif section.settings.section_width == 'full-width' %}
        --section-width:100%;
    {% endif %}
}
</style>

{% liquid
case section.settings.section_width
    when 'full-width'
    assign layout_container_class = 'full-width'
    when 'custom-width'
    assign layout_container_class = 'layout-container custom-width'
    when 'global-width'
    assign layout_container_class = 'layout-container global-width'
    else
    assign layout_container_class = 'layout-container'
endcase
%}

<div class="cm-brand-introduction {{ section.settings.custom_class }} {% if section.settings.remove_top_padding %}remove-top-space{% endif %} {% if section.settings.remove_bottom_padding %}remove-bottom-space{% endif %}" data-section-id="{{ section.id }}">
    <div class="{{ layout_container_class }}">

        {% if section.settings.heading != blank or section.settings.subheading != blank %}
            <div class="cm--header">
                <div class="cm-header-inner">
                    {% if section.settings.heading != blank %}
                        <div class="cm-heading">{{ section.settings.heading }}</div>
                    {% endif %}
                    {% if section.settings.subheading != blank %}
                        <div class="cm-subheading">{{ section.settings.subheading }}</div>
                    {% endif %}
                </div>
            </div>
        {% endif %}

        <div class="cm-inner">
            <div class="cm-content">
                <div class="cm-content-inner">
                    {% if section.settings.text1_heading != blank or section.settings.text1_text != blank %}
                    <div class="cm-content-item item-1">
                        <div class="cm-content-item-inner">
                            <div class="cm-content-item-title">{{ section.settings.text1_heading }}</div>
                            <div class="cm-content-item-text">{{ section.settings.text1_text }}</div>
                        </div>
                    </div>
                    {% endif %}
                    {% if section.settings.text2_heading != blank or section.settings.text2_text != blank %}
                    <div class="cm-content-item item-2">
                        <div class="cm-content-item-inner">
                            <div class="cm-content-item-title">{{ section.settings.text2_heading }}</div>
                            <div class="cm-content-item-text">{{ section.settings.text2_text }}</div>
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>
            {% if section.settings.video_url != blank %}
            <div class="cm-video">
                {% if section.settings.video_url != blank %}
                    <div class="cm-video-inner">
                        <div class="cm-video-item">
                            {% if section.settings.video_url.type == 'youtube' %}
                                <iframe src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                            {% elsif section.settings.video_url.type == 'vimeo' %}
                                <iframe src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
            </div>
            {% endif %}
        </div>
    </div>
</div>
