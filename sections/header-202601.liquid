          { "type": "header", "content": "活动" },
          { "type": "image_picker", "id": "image2", "label": "图片" },
          { "type": "text", "id": "title2", "label": "标题" },
          { "type": "url", "id": "link2", "label": "链接" },
  
          { "type": "header", "content": "活动" },
          { "type": "image_picker", "id": "image3", "label": "图片" },
          { "type": "text", "id": "title3", "label": "标题" },
          { "type": "url", "id": "link3", "label": "链接" },
  
          { "type": "header", "content": "活动" },
          { "type": "image_picker", "id": "image4", "label": "图片" },
          { "type": "text", "id": "title4", "label": "标题" },
          { "type": "url", "id": "link4", "label": "链接" }
        ]
      }
    ],
    "presets": [
      {
        "name": "顶部202601",
        "category": "Custom"
      }
    ]
  }
  {% endschema %}
  