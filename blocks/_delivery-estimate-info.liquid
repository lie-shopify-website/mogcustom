{% schema %}
{
  "name": "物流方式",
  "tag": null,
  "settings": [
    { "type": "textarea", "id": "shipping_method_name", "label": "物流方式名称", "default": "Priority Shipping" },
    { "type": "textarea", "id": "arrives_by", "label": "文本", "default": "Arrives by" },

    { "type": "header", "content": "时间信息" },
    { "type": "paragraph", "content": "这里填的是天数, 表示过了多少天之后, 达到什么状态. 比如发货时间填写5天, 即表示是5天后会发货, 前台会显示为对应的日期" },
    { "type": "number", "id": "order_shipping_days_min", "label": "发货时间(最小值)", "default": 5 },
    { "type": "number", "id": "order_shipping_days_max", "label": "发货时间(最大值)", "default": 7 },
    { "type": "number", "id": "order_delivery_days_min", "label": "到货时间(最小值)", "default": 15 },
    { "type": "number", "id": "order_delivery_days_max", "label": "到货时间(最大值)", "default": 17 },

    { "type": "header", "content": "弹层时间线文案" },
    { "type": "text", "id": "label_order", "label": "下单", "default": "Order placed" },
    { "type": "text", "id": "label_ship", "label": "发货", "default": "Ships" },
    { "type": "text", "id": "label_delivery", "label": "到达", "default": "Arrives" }
  ],
  "presets": [
    {
      "name": "物流方式"
    }
  ]
}
{% endschema %}

{% render '_delivery-estimate-info', block_settings: block.settings, block_id: block.id %}